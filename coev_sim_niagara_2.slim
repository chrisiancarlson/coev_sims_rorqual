// Record important stuff

ticks all 1 early() {
	moth.addSubpop("p1", N0_moth);
	plant.addSubpop("p2", N0_plant);
	plant.subpopulations.individuals.tagF=0.111111;
	moth.subpopulations.individuals.tagF=0.111111;
	p1.setSpatialBounds(c(0, 0, SIDE, SIDE));
	p1.individuals.setSpatialPosition(p1.pointUniform(N0_moth));
	
	p2.setSpatialBounds(c(0, 0, SIDE, SIDE));
	p2.individuals.setSpatialPosition(p2.pointUniform(N0_plant));

}

// record more important stuff: 
ticks all burn+1 early() {
	log = community.createLogFile(lname, logInterval=10);
	log.addTick();
	log.addPopulationSize(moth);
	log.addMeanSDColumns("moth", "p1.individuals.tagF;");
	log.addPopulationSize(plant);
	log.addMeanSDColumns("plant", "p2.individuals.tagF;");
}



ticks all late()  {
	plants =plant.subpopulations.individuals;
	moths =moth.subpopulations.individuals;
	plant.treeSeqRememberIndividuals(plants, permanent=F); // remember individuals only if ancestors of final population
	moth.treeSeqRememberIndividuals(moths, permanent=F); // remember individuals only if ancestors of final population
}


// output important stuff: 
ticks all samplings late() {
	//community.outputFull("~/model_output.txt");
	plants =plant.subpopulations.individuals;
	phenotypesP = plants.sumOfMutationsOfType(m2);
	plants.tagF=phenotypesP;
	
	moths = moth.subpopulations.individuals;
	phenotypesM = moths.sumOfMutationsOfType(m1);
	moths.tagF=phenotypesM;
	tick=community.tick;
	moth.outputFull(fname_m+tick+"_o.txt");
	plant.outputFull(fname_p+tick+"_o.txt");
	
